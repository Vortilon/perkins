# Copy to /root/perkins/.env on the VPS. Used by systemd (EnvironmentFile).
# Scopewrath MPD API (read-only)
SCOPEWRATH_API_URL=https://mpd.noteify.us
PERKINS_SECRET=your-random-secret-at-least-32-chars
PERKINS_DB_URL=sqlite:////root/perkins/perkins.db

# Bootstrap admin user (created on startup if no admin exists)
PERKINS_ADMIN_USERNAME=admin
PERKINS_ADMIN_PASSWORD=change-me
PERKINS_ADMIN_FIRST=Admin
PERKINS_ADMIN_LAST=User

# Service-to-service key (Scopewrath → Perkins). Set same value in both .env files.
# Leave empty to allow any caller on the internal network (not recommended in production).
PERKINS_SERVICE_KEY=
