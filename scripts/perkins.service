[Unit]
Description=Perkins AI FastAPI (Ollama report vs MPD)
After=network.target ollama.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/perkins
Environment="PATH=/root/perkins/venv/bin:/usr/local/bin:/usr/bin:/bin"
EnvironmentFile=-/root/perkins/.env
ExecStart=/root/perkins/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
